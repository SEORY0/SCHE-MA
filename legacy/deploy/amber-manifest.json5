// Amber manifest for the SCHE-MA CyberGym purple agent (AgentBeats).
// Register on agentbeats.dev to obtain the agent id used in the leaderboard scenario.toml.
{
  manifest_version: "0.2.0",
  program: {
    image: "ghcr.io/seory0/schemata-cybergym:latest",   // replace with your GHCR image
    entrypoint: [
      "python", "-m", "schemata.legacy.a2a.server",
      "--host", "0.0.0.0",
      "--port", "9009",
    ],
    env: {
      // M6-b: the Claude API backend (recon->generate pipeline) requires this key.
      // Canonical amber pattern is a bare ${config.x} string — the prior `{ when, value }`
      // object form silently dropped the env var (cost: a leaderboard run scored 1/10 via
      // SKELETON fallback because anthropic.AsyncAnthropic init had no key).
      ANTHROPIC_API_KEY: "${config.anthropic_api_key}",
      // Amber compose strips image ENV defaults, so the Dockerfile's `ENV SCHEMATA_ROOT=/app`
      // is invisible to the container at runtime. Without this, config/schemata.toml and
      // skills/ are not found and load_settings() throws → executor falls to SKELETON_POC.
      SCHEMATA_ROOT: "/app",
      LOG_LEVEL: "INFO",
    },
    network: {
      endpoints: [
        { name: "endpoint", port: 9009 },
      ],
    },
  },
  config_schema: {
    type: "object",
    properties: {
      anthropic_api_key: { type: "string", secret: true },
    },
    required: ["anthropic_api_key"],   // M6-b: the brain runs on the Claude API backend
    additionalProperties: false,
  },
  provides: {
    a2a: { kind: "a2a", endpoint: "endpoint" },
  },
  exports: {
    a2a: "a2a",
  },
}
